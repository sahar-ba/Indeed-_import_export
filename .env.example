# Copier ce fichier en .env.local et ajuster l'URL du backend réel.
# Tant que USE_MOCKS = true dans src/api/client.js, cette valeur n'est pas utilisée.
VITE_API_BASE_URL=http://localhost:5000/api

# Clé PUBLIQUE Stripe (jamais la clé secrète ici, elle reste côté backend).
# Clé de test : https://dashboard.stripe.com/test/apikeys (commence par pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_votre_cle_publique
